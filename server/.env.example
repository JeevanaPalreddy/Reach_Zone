PORT=5001

# Recommended: split credentials so @ and other characters in the password work.
MONGO_USER=your_atlas_username
MONGO_PASSWORD=your_plain_password
MONGO_HOST=cluster0.xxxxx.mongodb.net

# Optional (default Cluster0)
# MONGO_APP_NAME=Cluster0

# Alternative: single URI — password MUST be URL-encoded (@ → %40, # → %23, etc.)
# MONGO_URI=mongodb+srv://user:encodedPassword@cluster0.xxxxx.mongodb.net/?appName=Cluster0

JWT_SECRET=use_a_long_random_string
OPENAI_API_KEY=sk-...
